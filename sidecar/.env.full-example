# Simplified .env examples can be found in ../agents-examples/*/.env.example

# Agent logic
# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON my_agent.py

# Marketplace registration
AGENT_CAPABILITY=translate
AGENT_NAME=My Translator Agent
AGENT_DESCRIPTION=Translates text between languages
AGENT_PRICE=10000000
AGENT_ENDPOINT=https://my-agent.com
AGENT_FINAL_TIMEOUT=1200
AGENT_SYNC_TIMEOUT=30
AGENT_HAS_QUOTE=false

# TON wallet (address is derived automatically from the private key)
AGENT_WALLET_PK=...
AGENT_WALLET_SEED=

# Server
PORT=8080

# Payment
PAYMENT_TIMEOUT=300
ENFORCE_COMMENT_NONCE=true
REFUND_FEE_NANOTON=500000

# Network
TESTNET=false

# Local state & data files
# The processed-tx DB (processed_txs.<slug>.db) and stock DB (stock.<slug>.db)
# are auto-namespaced from AGENT_NAME and are NOT configurable via env.
# Only the state file can be overridden; default is .sidecar_state.<slug>.json.
# SIDECAR_STATE_PATH=.sidecar_state.json
JOBS_TTL_SECONDS=3600

# File store (temporary storage for agent file results)
FILE_STORE_DIR=file_store
FILE_STORE_TTL=900
